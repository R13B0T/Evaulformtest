<script>
const D = {
  product:null, reqType:null, otherProd:'',
  aeFirst:'', aeLast:'', aeEmail:'', aeState:'', aeMgr:'', nsId:'',
  cName:'', cSector:'', cContact:'', cPhone:'', cEmail:'', cLoc:'',
  cInit:null, cDM:'',
  oProb:'', oCurrent:'', oStage:'', oComp:null, oCompWho:'',
  oQty:'', oVal:'', oFeatures:'', oObjections:'', oNext:'',
  bcWhy:'', bcRollout:'', bcOutcomes:'',
  seedLoc:'', seedUser:'', leadership:null, community:null,
  dsCap:null, dsAreas:[], dsTrack:null, dsEng:null,
  lDate:'', lEndDate:'', demoFormat:null, attend:[], lAttendees:'',
  delivery:null, lAddr:'', lFreight:'', specialist:'', specialistEmail:'',
  training:null, lNotes:'', declName:''
};

let cur = 0;

function steps() {
  const base = ['s0','s1','s2','s3'];
  const isDS = D.product === 'Digital Skills';
  const isUnit = ['Evaluation Unit','Seed Unit'].includes(D.reqType);
  if (isUnit || isDS) base.push('s4');
  base.push('s5','s6');
  return base;
}

function go(idx) {
  const ss = steps();
  document.getElementById(ss[cur]).classList.remove('on');
  cur = idx;
  const sid = ss[cur];
  document.getElementById(sid).classList.add('on');
  renderProg();
  const isLast = cur === ss.length - 1;
  document.getElementById('btn-next').style.display = (isLast || sid === 's-done') ? 'none' : '';
  document.getElementById('btn-sub').style.display = isLast ? '' : 'none';
  document.getElementById('btn-row').style.display = sid === 's-done' ? 'none' : '';
  const back = document.getElementById('btn-back');
  cur > 0 ? back.classList.add('show') : back.classList.remove('show');

  if (isLast) {
    buildSummary();
    document.getElementById('decl-date').value = new Date().toLocaleDateString('en-AU',{day:'2-digit',month:'2-digit',year:'numeric'});
    const isUnit = ['Evaluation Unit','Seed Unit'].includes(D.reqType);
    document.getElementById('decl-demo-notice').style.display = D.reqType === 'Demonstration' ? '' : 'none';
    document.getElementById('decl-unit-notice').style.display = isUnit ? '' : 'none';
    document.getElementById('decl-mgr-ck').style.display = isUnit ? '' : 'none';
  }
  if (sid === 's5') {
    const isUnit2 = ['Evaluation Unit','Seed Unit'].includes(D.reqType);
    document.getElementById('demo-logis').style.display = D.reqType === 'Demonstration' ? '' : 'none';
    document.getElementById('unit-logis').style.display = isUnit2 ? '' : 'none';
    // Update end date hint for seed
    const hint = document.getElementById('end-date-hint');
    if (D.reqType === 'Seed Unit') hint.textContent = '(seed — agree with customer)';
    else if (D.reqType === 'Evaluation Unit') hint.textContent = '(auto-filled — 14 days)';
    else hint.textContent = '';
    autoFillEndDate();
  }
  if (sid === 's4') {
    const isSeed = D.reqType === 'Seed Unit';
    const isDS2 = D.product === 'Digital Skills';
    document.getElementById('bc-main').style.display = isDS2 ? 'none' : '';
    document.getElementById('ds-fields').style.display = isDS2 ? '' : 'none';
    document.getElementById('seed-fields').style.display = isSeed ? '' : 'none';
    document.getElementById('s4-title').textContent = isDS2 ? 'Digital Skills Details' : 'Business Case';
    document.getElementById('s4-sub').textContent = isDS2
      ? 'A few more questions to help us prepare the right demonstration.'
      : 'Evaluation and seed requests require justification to ensure we\'re investing in the right opportunities.';
    // Pre-fill auto fields
    fillAutoFields();
  }
  window.scrollTo({top:0, behavior:'smooth'});
}

function nxt() { if (valid()) { const ss = steps(); if (cur < ss.length - 1) go(cur + 1); } }
function prev() { if (cur > 0) go(cur - 1); }

// ── AUTO-FILL ──
function autoFillEndDate() {
  const dateEl = document.getElementById('l-date');
  const endEl  = document.getElementById('l-enddate');
  if (!dateEl.value) { endEl.value = ''; return; }
  if (D.reqType === 'Evaluation Unit') {
    const d = new Date(dateEl.value);
    d.setDate(d.getDate() + 14);
    endEl.value = d.toLocaleDateString('en-AU',{day:'2-digit',month:'2-digit',year:'numeric'});
  } else if (D.reqType === 'Seed Unit') {
    endEl.value = 'To be agreed with customer';
  } else {
    endEl.value = '';
  }
}

function updateRollup() {
  // Keep D in sync so fillAutoFields works when navigating to step 4
  D.oQty = document.getElementById('o-qty').value;
  D.oVal = document.getElementById('o-val').value;
  D.oFeatures = document.getElementById('o-features').value;
  D.oObjections = document.getElementById('o-objections').value;
}

function fillAutoFields() {
  const qty = document.getElementById('o-qty')?.value || '';
  const val = document.getElementById('o-val')?.value || '';
  const feat = document.getElementById('o-features')?.value || '';
  const obj = document.getElementById('o-objections')?.value || '';

  const rolloutEl = document.getElementById('bc-rollout');
  if (rolloutEl) {
    if (qty || val) {
      rolloutEl.value = `Estimated ${qty ? qty + ' units' : 'units unknown'}${val ? ' at AUD $' + val + ' ex GST' : ''} if successful.`;
    } else {
      rolloutEl.value = '';
      rolloutEl.placeholder = 'Enter quantity and deal value in the previous step to auto-fill this field.';
    }
  }
  const outcomeEl = document.getElementById('bc-outcomes');
  if (outcomeEl) {
    const parts = [];
    if (feat) parts.push('Must demonstrate: ' + feat.trim());
    if (obj) parts.push('Known concerns: ' + obj.trim());
    outcomeEl.value = parts.join(' | ');
    if (!parts.length) outcomeEl.placeholder = 'Complete features and concerns fields on the previous step to auto-fill this.';
  }
}

// ── CHIPS ──
function oneChip(gid, key, el, cb) {
  document.querySelectorAll('#'+gid+' .chip').forEach(c => c.classList.remove('on'));
  el.classList.add('on');
  D[key] = el.dataset.v;
  if (cb) cb();
}
function multiChip(gid, key, el) {
  el.classList.toggle('on');
  const v = el.dataset.v;
  if (!D[key]) D[key] = [];
  if (el.classList.contains('on')) { if (!D[key].includes(v)) D[key].push(v); }
  else D[key] = D[key].filter(x => x !== v);
}

