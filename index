// ── VALIDATION ──
function req(id, eid) {
  const el = document.getElementById(id);
  if (!el) return true;
  const ok = el.value.trim() !== '';
  el.classList.toggle('err', !ok);
  if (eid) { const e = document.getElementById(eid); if(e) e.classList.toggle('on', !ok); }
  return ok;
}
function reqEmail(id, eid) {
  const el = document.getElementById(id);
  if (!el) return true;
  const ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value.trim());
  el.classList.toggle('err', !ok);
  if (eid) { const e = document.getElementById(eid); if(e) e.classList.toggle('on', !ok); }
  return ok;
}
function clrErr(id) { const e = document.getElementById(id); if(e) e.classList.remove('on'); }
function markErr(id) { const e = document.getElementById(id); if(e) e.classList.add('on'); }

function valid() {
  const ss = steps(), sid = ss[cur];
  let ok = true;
  if (sid==='s0') {
    if (!D.product) { markErr('e-product'); ok=false; }
    if (!D.reqType) { markErr('e-type'); ok=false; }
    if (D.product==='Other Laptop Solution' && !req('other-prod')) ok=false;
    if (['Evaluation Unit','Seed Unit'].includes(D.reqType) && !req('ae-mgr','e-mgr')) ok=false;
  }
  if (sid==='s1') {
    if (!req('ae-first','e-ae-first')) ok=false;
    if (!req('ae-last','e-ae-last')) ok=false;
    if (!reqEmail('ae-email','e-ae-email')) ok=false;
    if (!req('ae-state','e-ae-state')) ok=false;
  }
  if (sid==='s2') {
    if (!req('c-name','e-c-name')) ok=false;
    if (!req('c-sector','e-c-sector')) ok=false;
    if (!req('c-contact','e-c-contact')) ok=false;
    if (!reqEmail('c-email','e-c-email')) ok=false;
    if (!req('c-loc','e-c-loc')) ok=false;
  }
  if (sid==='s3') {
    if (!req('o-prob','e-o-prob')) ok=false;
    if (!req('o-stage','e-o-stage')) ok=false;
  }
  if (sid==='s4') {
    if (D.product !== 'Digital Skills') {
      if (!req('bc-why','e-bc-why')) ok=false;
    }
    if (D.reqType==='Seed Unit' && !req('seed-loc','e-seed-loc')) ok=false;
  }
  if (sid==='s5') {
    if (!req('l-date','e-l-date')) ok=false;
    if (D.reqType==='Demonstration' && !D.demoFormat) { markErr('e-demoformat'); ok=false; }
  }
  if (sid==='s6') {
    if (!document.getElementById('decl-acc').checked) ok=false;
    if (['Evaluation Unit','Seed Unit'].includes(D.reqType) && !document.getElementById('decl-mgr-ch').checked) ok=false;
    if (!req('decl-name','e-decl-name')) ok=false;
    document.getElementById('decl-err').style.display = ok ? 'none' : '';
  }
  return ok;
}

// ── SUMMARY ──
function sv(k, v) {
  if (!v || v==='' || (Array.isArray(v) && !v.length)) return '';
  return `<div class="sum-row"><div class="sum-k">${k}</div><div class="sum-v">${Array.isArray(v)?v.join(', '):v}</div></div>`;
}
function block(title, rows) {
  const c = rows.filter(Boolean).join('');
  if (!c) return '';
  return `<div class="sum-block"><div class="sum-block-title">${title}</div>${c}</div>`;
}
function gv(id) { const e=document.getElementById(id); return e?e.value:''; }

function buildSummary() {
  const html = [
    block('Product &amp; Request',[
      sv('Product', D.product==='Other Laptop Solution' ? `Other — ${gv('other-prod')}` : D.product),
      sv('Request type', D.reqType),
      sv('Approving manager', gv('ae-mgr')),
    ]),
    block('Account Executive',[
      sv('Name', `${gv('ae-first')} ${gv('ae-last')}`),
      sv('Email', gv('ae-email')),
      sv('Branch', gv('ae-state')),
      sv('NetSuite Opp', gv('ns-id')),
    ]),
    block('Customer',[
      sv('Organisation', gv('c-name')),
      sv('Vertical', gv('c-sector')),
      sv('Contact', gv('c-contact')),
      sv('Email', gv('c-email')),
      sv('Phone', gv('c-phone')),
      sv('Location', gv('c-loc')),
      sv('Decision maker', gv('c-dm')),
      sv('Initiated by', D.cInit),
    ]),
    block('Opportunity',[
      sv('Problem', gv('o-prob')),
      sv('Current solution', gv('o-current')),
      sv('Stage', gv('o-stage')),
      sv('Competitors', D.oComp==='Yes — known' ? `Yes — ${gv('comp-who')}` : D.oComp),
      sv('Est. quantity', gv('o-qty')),
      sv('Est. value (ex GST)', gv('o-val') ? '$'+gv('o-val') : ''),
      sv('Next step', gv('o-next')),
    ]),
    (D.reqType!=='Demonstration' || D.product==='Digital Skills') ? block('Business Case',[
      sv('Why now', gv('bc-why')),
      sv('Projected rollout', gv('bc-rollout')),
      sv('Outcomes required', gv('bc-outcomes')),
      sv('Seed location', gv('seed-loc')),
      sv('Leadership aligned', D.leadership),
      sv('Reference potential', D.community),
    ]) : '',
    block('Logistics',[
      sv('Start date', gv('l-date')),
      sv('End / return date', gv('l-enddate')),
      sv('Demo format', D.demoFormat),
      sv('Attendees', D.attend?.length ? D.attend : null),
      sv('Delivery', D.delivery),
      sv('Product specialist', gv('l-specialist')),
      sv('Training', D.training),
    ]),
  ].join('');
  document.getElementById('summary-content').innerHTML = html;
}

// ── PROGRESS ──
function renderProg() {
  const ss = steps();
  const labelMap = {s0:0, s1:1, s2:2, s3:3, s4:4, s5:5, s6:6};
  const curIdx = labelMap[ss[cur]] ?? 0;
  for (let i = 0; i <= 6; i++) {
    const dot = document.getElementById('pd'+i);
    const lbl = document.getElementById('pl-'+i);
    const line = document.getElementById('pl'+i);
    if (!dot) continue;
    dot.className = 'prog-dot';
    lbl.className = 'prog-label';
    if (i < curIdx) {
      dot.classList.add('done'); dot.innerHTML = '✓';
      lbl.classList.add('done'); if(line) line.classList.add('done');
    } else if (i === curIdx) {
      dot.classList.add('active'); dot.innerHTML = `<span class="pn">${i+1}</span>`;
      lbl.classList.add('active'); if(line) line.classList.remove('done');
    } else {
      dot.innerHTML = `<span class="pn">${i+1}</span>`;
      if(line) line.classList.remove('done');
    }
  }
}

// ── SUBMIT ──
function submit() {
  if (!valid()) return;
  const refId = 'ASI-REQ-' + Math.floor(1000 + Math.random()*9000);
  const payload = {
    submittedAt: new Date().toISOString(), refId,
    product: D.product==='Other Laptop Solution' ? `Other — ${gv('other-prod')}` : D.product,
    reqType: D.reqType, manager: gv('ae-mgr'),
    ae: { name: `${gv('ae-first')} ${gv('ae-last')}`, email: gv('ae-email'), branch: gv('ae-state'), nsOpportunity: gv('ns-id') },
    customer: { name:gv('c-name'), vertical:gv('c-sector'), contact:gv('c-contact'), phone:gv('c-phone'), email:gv('c-email'), location:gv('c-loc'), decisionMaker:gv('c-dm'), initiatedBy:D.cInit },
    opportunity: { problem:gv('o-prob'), currentSolution:gv('o-current'), stage:gv('o-stage'), competitors:D.oComp, competitorNames:gv('comp-who'), estQty:gv('o-qty'), estValueExGST:gv('o-val'), features:gv('o-features'), objections:gv('o-objections'), nextStep:gv('o-next') },
    businessCase: { why:gv('bc-why'), rollout:gv('bc-rollout'), outcomes:gv('bc-outcomes'), seedLocation:gv('seed-loc'), seedUser:gv('seed-user'), leadership:D.leadership, community:D.community, dsCap:D.dsCap, dsAreas:D.dsAreas, dsTrack:D.dsTrack, dsEng:D.dsEng },
    logistics: { startDate:gv('l-date'), endDate:gv('l-enddate'), demoFormat:D.demoFormat, attend:D.attend, attendees:gv('l-attendees'), delivery:D.delivery, address:gv('l-addr'), freight:gv('l-freight'), specialist:gv('l-specialist'), specialistEmail:gv('l-specialist-email'), training:D.training, notes:gv('l-notes') },
    declaredBy: gv('decl-name')
  };
  console.log('ASI Form Payload:', JSON.stringify(payload, null, 2));
  const FLOW_URL = ''; // ← Paste Power Automate HTTP trigger URL here
  function done() {
    const ss = steps();
    document.getElementById(ss[cur]).classList.remove('on');
    document.getElementById('s-done').classList.add('on');
    document.getElementById('btn-row').style.display = 'none';
    document.getElementById('done-ref').textContent = refId;
    const isUnit = ['Evaluation Unit','Seed Unit'].includes(D.reqType);
    document.getElementById('done-msg').textContent = isUnit
      ? 'Your request has been logged and sent to your manager for approval. You\'ll be notified once approved and the specialist has been briefed.'
      : 'Your request has been logged and sent to the relevant product specialist to confirm session details.';
    renderProg(); window.scrollTo({top:0,behavior:'smooth'});
  }
  FLOW_URL ? fetch(FLOW_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).then(done).catch(done) : done();
}

renderProg();

// ── NETSUITE LOOKUP ──
const NS_MCP_URL = 'https://1099507-sb1.suitetalk.api.netsuite.com/services/mcp/v1/suiteapp/com.netsuite.mcpstandardtools';
let nsLinkedOpp = null;

function nsReady() {
  // Clear linked state if user edits the field
  if (nsLinkedOpp) nsClear();
  document.getElementById('ns-results').style.display = 'none';
  document.getElementById('ns-error').style.display = 'none';
}

function nsClear() {
  nsLinkedOpp = null;
  document.getElementById('ns-linked').style.display = 'none';
  document.getElementById('ns-id').value = '';
  document.getElementById('ns-results').style.display = 'none';
}

async function nsLookup() {
  const query = document.getElementById('ns-id').value.trim();
  if (!query) return;

  const loadEl  = document.getElementById('ns-loading');
  const errEl   = document.getElementById('ns-error');
  const resEl   = document.getElementById('ns-results');
  const btn     = document.getElementById('ns-btn');

  loadEl.style.display = 'flex';
  errEl.style.display  = 'none';
  resEl.style.display  = 'none';
  btn.disabled = true;
  btn.textContent = '…';

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: `You are a NetSuite lookup assistant. Search for opportunities matching the user's query and return ONLY a JSON array (no markdown, no preamble) with up to 5 results in this exact format:
[
  {
    "id": "NS record id",
    "title": "opportunity title",
    "customer": "customer/company name",
    "value": "deal value as number or null",
    "stage": "opportunity stage",
    "contact": "primary contact name or null",
    "closeDate": "expected close date or null"
  }
]
If no results found, return an empty array [].`,
        messages: [{ role: 'user', content: `Search NetSuite for opportunities matching: "${query}"` }],
        mcp_servers: [{ type: 'url', url: NS_MCP_URL, name: 'netsuite' }]
      })
    });

    const data = await response.json();
    const text = (data.content || [])
      .filter(b => b.type === 'text')
      .map(b => b.text)
      .join('');

    // Strip any markdown fences and parse
    const clean = text.replace(/```json|```/g, '').trim();
    let results = [];
    try { results = JSON.parse(clean); } catch(e) { results = []; }

    loadEl.style.display = 'none';
    btn.disabled = false;
    btn.textContent = 'Search NS';

    if (!Array.isArray(results) || results.length === 0) {
      errEl.innerHTML = `<div class="notice n-warn" style="margin-top:6px;margin-bottom:0">No opportunities found matching "<strong>${query}</strong>". Check the name or leave blank to link later.</div>`;
      errEl.style.display = '';
      return;
    }

    // Render results
    document.getElementById('ns-results-inner').innerHTML = results.map((r, i) => `
      <div class="ns-result-item" onclick="nsSelect(${i})">
        <div class="ns-result-name">${r.title || r.customer}</div>
        <div class="ns-result-meta">${r.customer}${r.value ? ' · $' + Number(r.value).toLocaleString() + ' ex GST' : ''}${r.stage ? ' · ' + r.stage : ''}</div>
      </div>
    `).join('');
    // Store results for selection
    window._nsResults = results;
    resEl.style.display = '';

  } catch(err) {
    loadEl.style.display = 'none';
    btn.disabled = false;
    btn.textContent = 'Search NS';
    errEl.innerHTML = `<div class="notice n-warn" style="margin-top:6px;margin-bottom:0">Could not connect to NetSuite. Check your network and try again.</div>`;
    errEl.style.display = '';
  }
}

function nsSelect(idx) {
  const r = (window._nsResults || [])[idx];
  if (!r) return;
  nsLinkedOpp = r;

  // Update the input to show selected title
  document.getElementById('ns-id').value = r.title || r.customer;

  // Hide results
  document.getElementById('ns-results').style.display = 'none';

  // Show linked badge
  document.getElementById('ns-linked-name').textContent = r.title || r.customer;
  document.getElementById('ns-linked-detail').textContent =
    [r.customer, r.value ? '$' + Number(r.value).toLocaleString() + ' ex GST' : null, r.stage]
    .filter(Boolean).join(' · ');
  document.getElementById('ns-linked').style.display = '';

  // ── AUTO-FILL form fields from NetSuite data ──
  // Customer name (only if not already filled)
  const cNameEl = document.getElementById('c-name');
  if (cNameEl && !cNameEl.value && r.customer) cNameEl.value = r.customer;

  // Deal value
  const valEl = document.getElementById('o-val');
  if (valEl && !valEl.value && r.value) valEl.value = Number(r.value).toLocaleString();

  // Opportunity stage — map NS stage to form stages
  const stageEl = document.getElementById('o-stage');
  if (stageEl && r.stage) {
    const stageMap = {
      'prospecting':        'New Lead',
      'new':                'New Lead',
      'qualification':      'New Lead',
      'value proposition':  'In Discussion',
      'needs analysis':     'In Discussion',
      'in discussion':      'In Discussion',
      'decision makers':    'Identified Decision Makers',
      'identified':         'Identified Decision Makers',
      'proposal':           'Proposal / Quote',
      'quote':              'Proposal / Quote',
      'negotiation':        'In Negotiation',
      'closed':             'In Negotiation',
    };
    const mapped = Object.entries(stageMap).find(([k]) =>
      r.stage.toLowerCase().includes(k)
    );
    if (mapped) {
      stageEl.value = mapped[1];
    }
  }

  // Contact name
  const contactEl = document.getElementById('c-contact');
  if (contactEl && !contactEl.value && r.contact) contactEl.value = r.contact;
}
